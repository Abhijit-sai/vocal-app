# =============================================================================
# My Leader — Environment Variables
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local or real secrets to version control.
# =============================================================================

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=                # public anon key
SUPABASE_SERVICE_ROLE_KEY=                    # KEEP SECRET — never expose to browser

# Telegram Bot — Citizen-facing
TELEGRAM_BOT_TOKEN=                           # From @BotFather (citizen bot)
TELEGRAM_WEBHOOK_SECRET=                      # Random 64-char hex for webhook validation

# Telegram Bot — Worker / internal-ops (separate bot)
WORKER_BOT_TOKEN=                             # From @BotFather (worker bot)
WORKER_WEBHOOK_SECRET=                        # Random 64-char hex for webhook validation
NEXT_PUBLIC_WORKER_BOT_USERNAME=              # Worker bot username without the leading @

# Organization (set once per deployment)
NEXT_PUBLIC_ORG_SLUG=demo                     # Used in ticket number prefix
ORG_ID=                                       # UUID of the organizations row in DB

# AI via OpenRouter (optional)
OPENROUTER_API_KEY=                           # From openrouter.ai
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-preview

# Cron job auth (for /api/cron/* endpoints)
CRON_SECRET=                                  # Random secret; passed as Bearer token by Vercel cron
